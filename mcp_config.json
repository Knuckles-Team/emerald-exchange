{
  "mcpServers": {
    "emerald-exchange": {
      "command": "uv",
      "args": [
        "run",
        "emerald-exchange-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "CRYPTOTOOL": "True",
        "DEBATETOOL": "True",
        "DERIVATIVESTOOL": "True",
        "EDGAR_IDENTITY": "Your Name your.email@example.com",
        "EDGAR_USER_AGENT": "Your Name your.email@example.com",
        "EMERALD_STAGE_APPROVAL_TOKEN": "",
        "EPISTEMIC_GRAPH_SOCKET": "/run/epistemic-graph.sock",
        "EPISTEMIC_GRAPH_TCP": "127.0.0.1:50051",
        "FUNDAMENTALSTOOL": "True",
        "MARKET_DATATOOL": "True",
        "MARKET_MAKINGTOOL": "True",
        "ORDERTOOL": "True",
        "POLY_TRADES_PATH": "/path/to/poly_trades.parquet",
        "PORTFOLIOTOOL": "True",
        "PREDICTION_MARKETTOOL": "True",
        "RISKTOOL": "True",
        "SIGNALTOOL": "True",
        "STATARBTOOL": "True",
        "STRATEGYTOOL": "True",
        "WALLET_INTELTOOL": "True"
      }
    }
  }
}
