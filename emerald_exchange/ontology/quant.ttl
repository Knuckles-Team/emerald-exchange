    rdfs:label "rule tier" ;
    rdfs:comment "Context-budget tier: full, mini, or nano." ;
    rdfs:domain :EngineeringRule ;
    rdfs:range xsd:string .

:safetyScore a owl:DatatypeProperty ;
    rdfs:label "safety score" ;
    rdfs:domain :EvaluationRecord ;
    rdfs:range xsd:float .

:severity a owl:DatatypeProperty ;
    rdfs:range xsd:string .

:sha a owl:DatatypeProperty ;
    rdfs:label "sha" ;
    rdfs:range xsd:string .

:sharedAs a owl:ObjectProperty ;
    rdfs:label "shared as" ;
    rdfs:comment "Links a strategy to its published strategy card." ;
    rdfs:domain :TradingStrategy ;
    rdfs:range :StrategyCardEntity .

:sharpeRatio a owl:DatatypeProperty ;
    rdfs:label "sharpe ratio" ;
    rdfs:range xsd:float .

:shortcutHitCount a owl:DatatypeProperty ;
    rdfs:label "shortcut hit count" ;
    rdfs:comment "Number of nodes found via pre-computed similarity shortcuts." ;
    rdfs:domain :UnifiedRAGConfig ;
    rdfs:range xsd:integer .

:shortcutRetrievalFrom a owl:ObjectProperty ;
    rdfs:label "shortcut retrieval from" ;
    rdfs:comment """Links a retrieval result to the similarity edge shortcut
    that accelerated its discovery.""" ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 .

:signalType a owl:DatatypeProperty ;
    rdfs:label "signal type" ;
    rdfs:range xsd:string .

:similarTo a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "similar to" ;
    rdfs:comment """Symmetric auto-similarity relationship discovered during memory
    node insertion. Weight decays exponentially over time.""" ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 .

:sizedBy a owl:ObjectProperty ;
    rdfs:label "sized by" ;
    rdfs:domain :ExecutionSignal ;
    rdfs:range :KellySizing .

:sourceUrl a owl:DatatypeProperty ;
    rdfs:label "source url" ;
    rdfs:range xsd:string .

:spawnedBy a owl:ObjectProperty ;
    rdfs:label "spawned by" ;
    rdfs:comment "Links an ephemeral SubAgent/Swarm back to its orchestrator." ;
    rdfs:domain :Agent ;
    rdfs:range :Agent .

:staleEdgeCount a owl:DatatypeProperty ;
    rdfs:label "stale edge count" ;
    rdfs:comment "Edges below prune threshold needing refresh." ;
    rdfs:domain :DistillationIndex ;
    rdfs:range xsd:integer .

:startedAtTime a owl:DatatypeProperty ;
    rdfs:label "started at time" ;
    rdfs:range xsd:dateTime ;
    rdfs:subPropertyOf prov:startedAtTime .

:state a owl:DatatypeProperty ;
    rdfs:label "state" ;
    rdfs:range xsd:string .

:status a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:comment "Lifecycle status of a graph node. Values: ACTIVE, DEPRECATED, ARCHIVED. Nodes with status ARCHIVED are excluded from standard search and retrieval operations." ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string .

:streamsTo a owl:ObjectProperty ;
    rdfs:label "streams to" ;
    rdfs:comment "Links a data source to its streaming channel." ;
    rdfs:domain :MarketDataSource ;
    rdfs:range :StreamChannel .

:subject a owl:DatatypeProperty ;
    rdfs:label "subject" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf dc:subject .

:supersedes a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "supersedes" ;
    rdfs:comment "Transitive: if ADR-C supersedes ADR-B supersedes ADR-A, then ADR-C supersedes ADR-A. Enables full decision lineage queries." ;
    rdfs:domain :ArchitectureDecisionRecord ;
    rdfs:range :ArchitectureDecisionRecord .

:supportsBeliefProp a owl:ObjectProperty ;
    rdfs:label "supports belief" ;
    rdfs:domain :Evidence ;
    rdfs:range :Belief .

:swarmDecidedBy a owl:ObjectProperty ;
    rdfs:label "swarm decided by" ;
    rdfs:comment "Links a trade to the swarm consensus that triggered it." ;
    rdfs:domain :FinancialTransaction ;
    rdfs:range :TradingSwarmEntity .

:symbolDefinedIn a owl:ObjectProperty ;
    rdfs:label "symbol defined in" ;
    rdfs:comment "Links a blast radius report to the file where the symbol is defined." ;
    rdfs:domain :BlastRadiusReport ;
    rdfs:range bfo:0000031 .

:symbolUsedIn a owl:ObjectProperty ;
    rdfs:label "symbol used in" ;
    rdfs:comment "Links a blast radius report to files where the symbol is used." ;
    rdfs:domain :BlastRadiusReport ;
    rdfs:range bfo:0000031 .

:syndicatable a owl:DatatypeProperty ;
    rdfs:label "syndicatable" ;
    rdfs:comment "Opt-in flag for cross-tenant knowledge federation." ;
    rdfs:domain :Concept ;
    rdfs:range xsd:boolean .

:targets a owl:ObjectProperty ;
    rdfs:label "targets" ;
    rdfs:comment "Links a MergeRequest to its target Repository." .

:taskDependsOn a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "task depends on" ;
    rdfs:comment "DAG dependency between tasks. Transitive for indirect dependencies." ;
    rdfs:domain :SwarmTaskRecord ;
    rdfs:range :SwarmTaskRecord .

:testedHypothesis a owl:ObjectProperty ;
    rdfs:label "tested hypothesis" ;
    rdfs:comment "Links a strategy to a research hypothesis it validated." ;
    rdfs:domain :TradingStrategy ;
    rdfs:range :ResearchHypothesis .

:testedInterpretability a owl:ObjectProperty ;
    rdfs:label "tested interpretability" ;
    rdfs:domain :IModel ;
    rdfs:range :InterpretabilityTest .

:testsHypothesis a owl:ObjectProperty ;
    rdfs:label "tests hypothesis" ;
    rdfs:domain :ExplorationExperiment ;
    rdfs:range :Hypothesis .

:timestamp a owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

:title a owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf dc:title .

:tokenBudgetMax a owl:DatatypeProperty ;
    rdfs:label "token budget max" ;
    rdfs:comment "Hard token ceiling for the research session." ;
    rdfs:domain :ResearchSession ;
    rdfs:range xsd:integer .

:triggered a owl:ObjectProperty ;
    rdfs:label "triggered" ;
    rdfs:comment "Links a MergeRequest or Commit to the Pipeline it triggered." .

:triggeredAction a owl:ObjectProperty ;
    rdfs:label "triggered action" ;
    rdfs:domain :Event ;
    rdfs:range :Action .

:triggeredBy a owl:ObjectProperty ;
    rdfs:label "triggered by" ;
    rdfs:domain :Event ;
    rdfs:range :Event .

:triggeredDoomLoop a owl:ObjectProperty ;
    rdfs:label "triggered doom loop" ;
    rdfs:comment "Links a process to a doom loop incident it triggered." ;
    rdfs:domain bfo:0000015 ;
    rdfs:range :DoomLoopIncident .

:trustedAnswer a owl:DatatypeProperty ;
    rdfs:label "trusted answer" ;
    rdfs:comment "The validated, factual answer for this IdeaBlock." ;
    rdfs:domain :IdeaBlock ;
    rdfs:range xsd:string .

:verifiedBy a owl:ObjectProperty ;
    rdfs:label "verified by" ;
    rdfs:comment "Links a manifest to its verification evidence." ;
    rdfs:domain :ChangeManifest .

:violationCount a owl:DatatypeProperty ;
    rdfs:label "violation count" ;
    rdfs:comment "Number of times this constraint has been violated.",
        "Number of times this rule was violated." ;
    rdfs:domain :ConstraintState,
        :EngineeringRule ;
    rdfs:range xsd:integer .

:visualizes a owl:ObjectProperty ;
    rdfs:label "visualizes" ;
    rdfs:comment "A frontend package visualizes data from another entity." ;
    rdfs:domain :FrontendPackage ;
    rdfs:range owl:Thing .

:wasAttributedTo a owl:ObjectProperty ;
    rdfs:label "was attributed to" ;
    rdfs:comment "Provenance: who is responsible for this entity." ;
    rdfs:subPropertyOf prov:wasAttributedTo .

:wasDerivedFrom a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "was derived from" ;
    rdfs:comment "Provenance: transitive entity derivation chain." ;
    rdfs:subPropertyOf prov:wasDerivedFrom .

:wasGeneratedBy a owl:ObjectProperty ;
    rdfs:label "was generated by" ;
    rdfs:comment "Provenance: what Activity generated this Entity." ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

<http://knuckles.team/kg/quant> a owl:Ontology ;
    rdfs:label "Quant & Finance Domain Extension" ;
    rdfs:comment "Domain extension for quant trading, crypto, and finance." ;
    owl:imports <http://knuckles.team/kg> .

bfo:0000002 owl:disjointWith bfo:0000003 .

:AgentCalibration a owl:Class ;
    rdfs:label "Agent Calibration" ;
    rdfs:comment "A Brier-based reputation/calibration record CALIBRATION_OF an Agent persona, used to compute calibration-weighted SwarmConsensus role weights. CONCEPT:KG-2.27" ;
    rdfs:subClassOf :OutcomeEvaluation .

:AgentSwarm a owl:Class ;
    rdfs:label "Agent Swarm" ;
    rdfs:comment "A dynamic, hierarchically synthesized team of AI agents." ;
    rdfs:subClassOf :Team .

:AlphaFactor a owl:Class ;
    rdfs:label "Alpha Factor" ;
    rdfs:comment "A predictive alpha factor with IC/IR statistics. Subclass of StationaryFeature. CONCEPT:KG-2.6" ;
    rdfs:subClassOf :StationaryFeature .

:BacktestMetric a owl:Class ;
    rdfs:label "backtest metric" ;
    rdfs:comment "An individual metric from a backtest or evaluation run." ;
    rdfs:subClassOf :RegistryNode .

:BehavioralBias a owl:Class ;
    rdfs:label "Behavioral Bias" ;
    rdfs:comment "A diagnosed behavioural-finance bias EXHIBITED_BY a TraderProfile: disposition effect, overtrading, momentum-chasing, or anchoring — each with a numeric metric and severity. CONCEPT:KG-2.26" ;
    rdfs:subClassOf :OutcomeEvaluation .

:ChartPattern a owl:Class ;
    rdfs:label "Chart Pattern" ;
    rdfs:comment "A detected visual chart pattern (double top, breakout, etc.). CONCEPT:KG-2.6" ;
    rdfs:subClassOf bfo:0000031 .

:DataFetchRecord a owl:Class ;
    rdfs:label "data fetch record" ;
    rdfs:comment "Immutable provenance record of a data fetch operation." ;
    rdfs:subClassOf :RegistryNode .

:DecisionHeuristic a owl:Class ;
    rdfs:label "Decision Heuristic" ;
    rdfs:comment "An explicit, evaluable investor decision rule (e.g. Graham P/E<15, Buffett ROE>=15%) HEURISTIC_OF a persona Agent. Borrowed from Fincept's granular persona registry. CONCEPT:KG-2.28" ;
    rdfs:subClassOf :Procedure .

:FormalRelation a owl:Class ;
    rdfs:label "Formal Relation" ;
    rdfs:comment "A mathematically formal relation (e.g. Equivalence, Partial Order). BFO:GenericallyDependentContinuant." ;
    rdfs:subClassOf bfo:0000031 .

:FrontendPackage a owl:Class ;
    rdfs:label "Frontend Package" ;
    rdfs:comment "A user-facing frontend (TUI or WebUI) package." ;
    rdfs:subClassOf :EcosystemPackage .

:InterpretabilityTest a owl:Class ;
    rdfs:label "interpretability test" ;
    rdfs:comment "A quantitative test result measuring whether an LLM can simulate model predictions from __str__() output alone." ;
    rdfs:subClassOf :EvaluationRecord .

:KernelPackage a owl:Class ;
    rdfs:label "Kernel Package" ;
    rdfs:comment "The core agent-utilities kernel package." ;
    rdfs:subClassOf :EcosystemPackage .

:KnowledgeGap a owl:Class ;
    rdfs:label "Knowledge Gap" ;
    rdfs:comment "An identified gap in the agent's knowledge. Subclass of Observation." ;
    rdfs:subClassOf :Observation .

:KronosModel a owl:Class ;
    rdfs:label "Kronos Foundation Model" ;
    rdfs:comment "A K-line tokenizer and autoregressive transformer for candlestick forecasting. CONCEPT:KG-2.6" ;
    rdfs:subClassOf :NeuralNetworkModel .

:MarketDataSource a owl:Class ;
    rdfs:label "Market Data Source" ;
    rdfs:comment "A market data provider (yfinance, CCXT, synthetic). CONCEPT:KG-2.6" ;
    rdfs:subClassOf :Tool .

:MarketRegime a owl:Class ;
    rdfs:label "Market Regime" ;
    rdfs:comment "A specific topological state of the market." ;
    rdfs:subClassOf :Phase .

:MergeRequest a owl:Class ;
    rdfs:label "Merge Request" ;
    rdfs:comment "A merge request or pull request. BFO:Process." ;
    rdfs:subClassOf bfo:0000015 .

:PaymentProofEntity a owl:Class ;
    rdfs:label "Payment Proof" ;
    rdfs:comment "An x402 payment proof attesting a completed autonomous payment. CONCEPT:KG-2.6" ;
    rdfs:subClassOf :FinancialTransaction .

:PortfolioAllocation a owl:Class ;
    rdfs:label "Portfolio Allocation" ;
    rdfs:comment "An optimized weight assignment (MVO, Risk Parity, Black-Litterman). CONCEPT:KG-2.6" ;
    rdfs:subClassOf bfo:0000031 .

:Principle rdfs:subClassOf :MotivationLayer .

:ProfitAttribution a owl:Class ;
    rdfs:label "Profit Attribution" ;
    rdfs:comment "Alpha/beta/residual P&L decomposition. CONCEPT:KG-2.6" ;
    rdfs:subClassOf :OutcomeEvaluation .

:PromptChain a owl:Class ;
    rdfs:label "Prompt Chain" ;
    rdfs:comment "A declarative multi-step prompt pipeline with intermediate validation and conditional branching. BFO:Process via Procedure." ;
    rdfs:subClassOf :Procedure .

:Region a owl:Class ;
    rdfs:label "Region" ;
    rdfs:comment "A geographic region/country affected by a GeopoliticalRisk or in an asset's operating footprint. CONCEPT:KG-2.30" ;
    rdfs:subClassOf :Concept .

:ResearchHypothesis a owl:Class ;
    rdfs:label "Research Hypothesis" ;
    rdfs:comment "A testable trading hypothesis in the research autopilot. CONCEPT:KG-2.6" ;
    rdfs:subClassOf bfo:0000031 .

:ResourceUsage a owl:Class ;
    rdfs:label "Resource Usage Record" ;
    rdfs:comment "Per-session resource consumption tracking (tokens, cost, latency). BFO:Process." ;
    rdfs:subClassOf bfo:0000015 .

:RiskLimit a owl:Class ;
    rdfs:label "Risk Limit" ;
    rdfs:comment "A risk management policy (max position, VaR limit, drawdown limit). CONCEPT:KG-2.6" ;
    rdfs:subClassOf :Policy .

:RiskMitigation a owl:Class ;
    rdfs:label "risk mitigation" ;
    rdfs:comment "A proposed or applied mitigation for a risk factor." ;
    rdfs:subClassOf :RegistryNode .

:RiskProfile a owl:Class ;
    rdfs:label "Risk Profile" ;
    rdfs:comment "The quantified or qualitative risk posture of an entity." ;
    rdfs:subClassOf bfo:0000031 .

:RuleBook a owl:Class ;
    rdfs:label "Rule Book" ;
    rdfs:comment """A canonical software engineering book that is the source
of engineering rules (e.g., 'Clean Architecture', 'Domain-Driven Design').
Subclass of CreativeWork for Dublin Core / BIBO alignment.""" ;
    rdfs:subClassOf :CreativeWork .

:Sector a owl:Class ;
    rdfs:label "Sector" ;
    rdfs:comment "An industry/GICS sector affected by a GeopoliticalRisk or in an asset's revenue attribution. CONCEPT:KG-2.30" ;
    rdfs:subClassOf :Concept .

:SentimentSource a owl:Class ;
    rdfs:label "Sentiment Source" ;
    rdfs:comment "A provenance channel for a SentimentFact (filing, analyst, news, social, ...) carrying a credibility prior. CONCEPT:KG-2.29" ;
    rdfs:subClassOf :Concept .

:Skill rdfs:subClassOf :ApplicationLayer .

:StateSpaceModel a owl:Class ;
    rdfs:label "State Space Model" ;
    rdfs:comment "A mathematical model to estimate unobservable, time-varying states from noisy observations." ;
    rdfs:subClassOf bfo:0000031 .

:StationaryFeature a owl:Class ;
    rdfs:label "Stationary Feature" ;
    rdfs:comment "A mathematically stationary market feature." ;
    rdfs:subClassOf bfo:0000031 .

:StochasticProcess a owl:Class ;
    rdfs:label "Stochastic Process" ;
    rdfs:comment "A mathematical object defined as a family of random variables, such as a Markov Chain." ;
    rdfs:subClassOf bfo:0000015 .

:StrategyCardEntity a owl:Class ;
    rdfs:label "Strategy Card" ;
    rdfs:comment "A shareable strategy card with configuration and performance data. CONCEPT:KG-2.6" ;
    rdfs:subClassOf bfo:0000031 .

:StrategyExport a owl:Class ;
    rdfs:label "Strategy Export" ;
    rdfs:comment "A platform-specific strategy code export (Pine Script, MQL5, TDX). CONCEPT:KG-2.6" ;
    rdfs:subClassOf bfo:0000031 .

:StrategyLayer a owl:Class ;
    rdfs:label "Strategy Layer" ;
    rdfs:comment "ArchiMate Strategy Layer — capabilities, courses of action, resources." ;
    rdfs:subClassOf :ArchiMateElement .

:SwarmRun a owl:Class ;
    rdfs:label "swarm run" ;
    rdfs:comment "Execution record of a swarm preset run." ;
    rdfs:subClassOf :RegistryNode .

:TraderProfile a owl:Class ;
    rdfs:label "Trader Profile" ;
    rdfs:comment "An aggregate behavioural portrait of a trader from their closed roundtrips (win rate, holding period, PnL ratio, max drawdown). Borrowed from Vibe-Trading's shadow account, persisted as a queryable learning signal. CONCEPT:KG-2.26" ;
    rdfs:subClassOf :OutcomeEvaluation .

:TradingSwarmEntity a owl:Class ;
    rdfs:label "Trading Swarm" ;
    rdfs:comment "A multi-agent swarm with specialized roles for collaborative trading. CONCEPT:KG-2.6" ;
    rdfs:subClassOf bfo:0000027 .

:broader a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "broader" ;
    rdfs:comment "SKOS broader relationship — transitive concept hierarchy." ;
    rdfs:subPropertyOf skos:broader .

:editedInRound a owl:ObjectProperty ;
    rdfs:label "edited in round" ;
    rdfs:comment "Links a component edit to its parent evolution round manifest." ;
    rdfs:domain :ComponentEditRecord ;
    rdfs:range :ChangeManifest .

:partOf a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "part of" .

:provides a owl:ObjectProperty ;
    rdfs:label "provides" ;
    rdfs:domain :Agent ;
    rdfs:range :Tool .

:Belief owl:disjointWith :Fact .

:BusinessLayer a owl:Class ;
    rdfs:label "Business Layer" ;
    rdfs:comment "ArchiMate Business Layer — business services, processes, roles." ;
    rdfs:subClassOf :ArchiMateElement .

:CitationEdge a owl:Class ;
    rdfs:label "Citation Edge" ;
    rdfs:comment """A directional citation relationship between two research papers
    with semantic metadata. BFO:GenericallyDependentContinuant.
    Enables transitive citation graph traversal (CONCEPT:KG-2.7).""" ;
    rdfs:subClassOf bfo:0000031 .

:ExplorationExperiment a owl:Class ;
    rdfs:label "Exploration Experiment" ;
    rdfs:comment "A structured experiment to test a hypothesis. BFO:Process via Procedure." ;
    rdfs:subClassOf :Procedure .

:Goal rdfs:subClassOf :MotivationLayer .

:KellySizing a owl:Class ;
    rdfs:label "Kelly Sizing" ;
    rdfs:comment "A position sizing procedure using the Kelly Criterion." ;
    rdfs:subClassOf :Procedure .

:ModelDisplay a owl:Class ;
    rdfs:label "model display" ;
    rdfs:comment "An optimized display representation of a model's __str__() output, decoupled from predict() logic." ;
    rdfs:subClassOf :RegistryNode .

:MotivationLayer a owl:Class ;
    rdfs:label "Motivation Layer" ;
    rdfs:comment "ArchiMate Motivation Layer — goals, principles, requirements, constraints." ;
    rdfs:subClassOf :ArchiMateElement .

:Order a owl:Class ;
    rdfs:label "order" ;
    rdfs:comment "An order in the trading pipeline lifecycle." ;
    rdfs:subClassOf :RegistryNode .

:OrderVersion a owl:Class ;
    rdfs:label "Order Version" ;
    rdfs:comment "An immutable versioned snapshot of a trading order. CONCEPT:KG-2.6" ;
    rdfs:subClassOf bfo:0000031 .

:Portfolio a owl:Class ;
    rdfs:label "portfolio" ;
    rdfs:comment "An aggregation of positions with allocation tracking." ;
    rdfs:subClassOf :RegistryNode .

:Position a owl:Class ;
    rdfs:label "position" ;
    rdfs:comment "An open or closed position in a portfolio." ;
    rdfs:subClassOf :RegistryNode .

:ResearchSession a owl:Class ;
    rdfs:label "Research Session" ;
    rdfs:comment """An isolated research sub-agent execution session with its own
    token budget, tool whitelist, and findings. BFO:Process. Adapted from
    ml-intern's research_tool.py (CONCEPT:KG-2.7).""" ;
    rdfs:subClassOf bfo:0000015 .

:RiskAssessment a owl:Class ;
    rdfs:label "risk assessment" ;
    rdfs:comment "Domain-agnostic risk evaluation with multi-dimensional scoring." ;
    rdfs:subClassOf :RegistryNode .

:SentimentFact a owl:Class ;
    rdfs:label "Sentiment Fact" ;
    rdfs:comment "A normalized, credibility-weighted sentiment observation ABOUT a FinancialInstrument and DERIVED_FROM a Source, with polarity, magnitude and a source-skepticism weight. Fused per-entity into a SENTIMENT_ANALYST AgentSignal consumed by SwarmConsensus. CONCEPT:KG-2.29" ;
    rdfs:subClassOf :Observation .

:SimilarityEdge a owl:Class ;
    rdfs:label "Similarity Edge" ;
    rdfs:comment """An auto-created similarity link between memory nodes.
    Uses cosine similarity thresholding with exponential decay scoring.
    BFO:GenericallyDependentContinuant. Adapted from contextplus (CONCEPT:KG-2.3).""" ;
    rdfs:subClassOf bfo:0000031 .

:StreamChannel a owl:Class ;
    rdfs:label "Stream Channel" ;
    rdfs:comment "A real-time pub/sub streaming topic. CONCEPT:KG-2.6" ;
    rdfs:subClassOf bfo:0000031 .

:SwarmPreset a owl:Class ;
    rdfs:label "swarm preset" ;
    rdfs:comment "A declarative multi-agent workflow preset stored in the KG." ;
    rdfs:subClassOf :RegistryNode .

:SwarmTaskRecord a owl:Class ;
    rdfs:label "swarm task record" ;
    rdfs:comment "Individual task execution record within a swarm run." ;
    rdfs:subClassOf :RegistryNode .

:TechnologyLayer a owl:Class ;
    rdfs:label "Technology Layer" ;
    rdfs:comment "ArchiMate Technology Layer — nodes, devices, infrastructure services." ;
    rdfs:subClassOf :ArchiMateElement .

:TradingSignal a owl:Class ;
    rdfs:label "trading signal" ;
    rdfs:comment "A buy/sell/hold signal with confidence and attribution." ;
    rdfs:subClassOf :RegistryNode .

:UnifiedRAGConfig a owl:Class ;
    rdfs:label "Unified RAG Config" ;
    rdfs:comment """Configuration and performance snapshot for KG-native unified
    retrieval combining similarity-edge shortcuts, spectral cluster
    scoping, and hybrid scoring. BFO:SpecificallyDependentContinuant.
    (CONCEPT:KG-2.3).""" ;
    rdfs:subClassOf bfo:0000020 .

:Account a owl:Class ;
    rdfs:label "Account" ;
    rdfs:comment "A financial account. BFO:GenericallyDependentContinuant." ;
    rdfs:subClassOf bfo:0000031 .

:ApplicationLayer a owl:Class ;
    rdfs:label "Application Layer" ;
    rdfs:comment "ArchiMate Application Layer — application components, services, data objects." ;
    rdfs:subClassOf :ArchiMateElement .

:DataConnector a owl:Class ;
    rdfs:label "data connector" ;
    rdfs:comment "A registered external data source with health and rate-limit metadata." ;
    rdfs:subClassOf :RegistryNode,
        :TechnologyLayer .

:DistillationIndex a owl:Class ;
    rdfs:label "Distillation Index" ;
    rdfs:comment """A snapshot of the pre-computed similarity edge index health.
    Tracks coverage, staleness, and recommendations for maintenance.
    BFO:SpecificallyDependentContinuant. (CONCEPT:KG-2.6).""" ;
    rdfs:subClassOf bfo:0000020 .

:DoomLoopIncident a owl:Class ;
    rdfs:label "Doom Loop Incident" ;
    rdfs:comment """A detected tool-call repetition pattern including consecutive
    identical calls and repeating multi-tool sequences. BFO:Process.
    Adapted from ml-intern's doom_loop.py (CONCEPT:OS-5.0).""" ;
    rdfs:subClassOf bfo:0000015 .

:ExecutionSignal a owl:Class ;
    rdfs:label "Execution Signal" ;
    rdfs:comment "A directional market signal generated by a model." ;
    rdfs:subClassOf bfo:0000031 .

:FinancialInstrument a owl:Class ;
    rdfs:label "Financial Instrument" ;
    rdfs:comment "A financial instrument (stock, bond, derivative, crypto). BFO:GenericallyDependentContinuant. Aligned to FIBO." ;
    rdfs:seeAlso fibo-fi:FinancialInstrument ;
    rdfs:subClassOf bfo:0000031 .

:GeopoliticalRisk a owl:Class ;
    rdfs:label "Geopolitical Risk" ;
    rdfs:comment "A reasoned geopolitical risk factor (conflict, sanctions, supply-chain chokepoint, election/regime-change) with severity, likelihood and an affected sector/region footprint. Holdings are exposedTo it (making 'which holdings are exposed to risk X' a graph query) and it transmits into the existing StressTestEngine shock path. CONCEPT:KG-2.30" ;
    rdfs:subClassOf :RiskFactor .

:OrchestrationCycle a owl:Class ;
    rdfs:label "Orchestration Cycle" ;
    rdfs:comment """A complete research orchestration cycle connecting discovery,
    citation traversal, similarity linking, and cluster refresh.
    BFO:Process. (CONCEPT:KG-2.7).""" ;
    rdfs:subClassOf bfo:0000015 .

:PromptChainStep a owl:Class ;
    rdfs:label "Prompt Chain Step" ;
    rdfs:comment "A single step within a PromptChain. BFO:Process via Action." ;
    rdfs:subClassOf :Action .

:RiskFactor a owl:Class ;
    rdfs:label "risk factor" ;
    rdfs:comment "An individual risk factor contributing to an assessment." ;
    rdfs:subClassOf :RegistryNode .

:BacktestRun a owl:Class ;
    rdfs:label "backtest run" ;
    rdfs:comment "A complete backtesting or evaluation run record." ;
    rdfs:subClassOf :RegistryNode .

:BlastRadiusReport a owl:Class ;
    rdfs:label "Blast Radius Report" ;
    rdfs:comment """A symbol-level impact analysis report tracking how widely a
    code symbol is used across the codebase. BFO:SpecificallyDependentContinuant.
    Adapted from contextplus (CONCEPT:KG-2.5).""" ;
    rdfs:subClassOf bfo:0000020 .

:ConstraintState a owl:Class ;
    rdfs:label "Constraint State" ;
    rdfs:comment """A hierarchical constraint with enforcement level tracking.
Subclass of Policy — inherits governance semantics. Tracks
current_level (PROMPT→TOOL_DESCRIPTION→MIDDLEWARE→TOOL_IMPLEMENTATION),
violation_count, and escalation history.""" ;
    rdfs:subClassOf :Policy .

:DistillationRound a owl:Class ;
    rdfs:label "Distillation Round" ;
    rdfs:comment """A single iteration of the knowledge deduplication process.
    BFO:Process. Tracks blocks_before, blocks_after, and similarity_threshold
    for reproducible distillation lineage (CONCEPT:KG-2.2).""" ;
    rdfs:subClassOf bfo:0000015 .

:FinancialTransaction a owl:Class ;
    rdfs:label "Financial Transaction" ;
    rdfs:comment "A financial transaction event. BFO:Process. Aligned to FIBO." ;
    rdfs:subClassOf bfo:0000015 .

:PrioritizedTask a owl:Class ;
    rdfs:label "Prioritized Task" ;
    rdfs:comment "A task with multi-factor priority scoring (urgency, impact, effort, risk). BFO:Process via Action." ;
    rdfs:subClassOf :Action .

:Strategy a owl:Class ;
    rdfs:label "strategy" ;
    rdfs:comment "A named trading strategy with parameters and performance lineage." ;
    rdfs:subClassOf :RegistryNode .

:Task a owl:Class ;
    rdfs:label "Task" ;
    rdfs:comment """A discrete work unit assigned to an agent. BFO:Process.
Aligned to prov:Activity for provenance tracking (wasGeneratedBy).""" ;
    rdfs:seeAlso prov:Activity ;
    rdfs:subClassOf bfo:0000015 .

:Tool rdfs:subClassOf :ApplicationLayer .

:ArchiMateElement a owl:Class ;
    rdfs:label "ArchiMate Element" ;
    rdfs:comment "Root class for ArchiMate 3.2 metamodel element mappings." .

:ComponentEditRecord a owl:Class ;
    rdfs:label "Component Edit Record" ;
    rdfs:comment """A granular edit applied to a harness component file.
BFO:GenericallyDependentContinuant — tracks file_path, component_type,
git_commit_sha, predicted_fixes, and predicted_regressions.""" ;
    rdfs:seeAlso prov:Entity ;
    rdfs:subClassOf bfo:0000031 .

:IdeaBlock a owl:Class ;
    rdfs:label "IdeaBlock" ;
    rdfs:comment """An atomic, structured knowledge unit containing a critical
    question, trusted answer, governance tags, and entity references.
    BFO:GenericallyDependentContinuant. Aligned to skos:Concept.
    Derived from Blockify's IdeaBlock specification (CONCEPT:KG-2.2).""" ;
    rdfs:subClassOf :Concept,
        bfo:0000031 .

:NeuralNetworkModel a owl:Class ;
    rdfs:label "Neural Network Model" ;
    rdfs:comment "A trained neural network model." ;
    rdfs:subClassOf :Tool .

:SpectralCluster a owl:Class ;
    rdfs:label "Spectral Cluster" ;
    rdfs:comment """A semantically coherent cluster discovered via spectral
    decomposition of the normalized Laplacian. Inherits SKOS taxonomy
    semantics for auto-hierarchical concept taxonomies. Tuning-free
    k-selection via eigengap heuristic (CONCEPT:KG-2.5).""" ;
    rdfs:subClassOf skos:Concept .

:ArchitectureDecisionRecord a owl:Class ;
    rdfs:label "Architecture Decision Record" ;
    rdfs:comment "Queryable decision trace capturing who decided what, why, under what authority, and what alternatives were considered. Lifecycle: proposed → accepted → deprecated → superseded." .

:ChangeManifest a owl:Class ;
    rdfs:label "Change Manifest" ;
    rdfs:comment """A versioned record of harness edits with falsifiable predictions.
BFO:GenericallyDependentContinuant — an information entity that tracks
component-level changes across evolution rounds. wasDerivedFrom is
transitive, enabling automatic lineage tracking across manifests.""" ;
    rdfs:subClassOf bfo:0000031 .

:MCPServerPackage a owl:Class ;
    rdfs:label "MCP Server Package" ;
    rdfs:comment "An MCP server package providing tool integrations." ;
    rdfs:subClassOf :EcosystemPackage .

:TradingStrategy a owl:Class ;
    rdfs:label "Trading Strategy" ;
    rdfs:comment "An algorithmic trading procedure." ;
    rdfs:subClassOf :Procedure .

:EvaluationRecord a owl:Class ;
    rdfs:label "Multi-Dimensional Evaluation Record" ;
    rdfs:comment "Multi-dimensional quality evaluation with per-dimension scoring. Subclass of Observation." ;
    rdfs:subClassOf :Observation .

:IModel a owl:Class ;
    rdfs:label "interpretable model" ;
    rdfs:comment "An evolved agent-interpretable ML model class with dual-axis fitness (accuracy + LLM readability). Based on arXiv:2605.03808." ;
    rdfs:subClassOf :RegistryNode .

:Policy rdfs:subClassOf :BusinessLayer .

:Concept rdfs:subClassOf :StrategyLayer .

:EcosystemPackage a owl:Class ;
    rdfs:label "Ecosystem Package" ;
    rdfs:comment "A software package within the agent-utilities ecosystem." ;
    rdfs:subClassOf bfo:0000004 .

:EngineeringRule a owl:Class ;
    rdfs:label "Engineering Rule" ;
    rdfs:comment """A software engineering rule derived from a canonical book.
Subclass of Principle — inherits strength, scope, and derivation semantics.
Adds tier (full/mini/nano), rule classification, bias correction tracking,
and AHE efficacy scoring for evolutionary rule selection.""" ;
    rdfs:subClassOf :Principle .

:Agent rdfs:subClassOf :ApplicationLayer ;
    owl:disjointWith :Tool .

